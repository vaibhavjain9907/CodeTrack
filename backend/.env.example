# Copy this file to `.env` and fill in real values. Never commit `.env` itself.

PROJECT_NAME=CodeTrack
ENVIRONMENT=development

# Generate a strong key: `openssl rand -hex 32`
SECRET_KEY=changeme_generate_a_real_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# Matches docker-compose service name `db`
DATABASE_URL=postgresql://codetrack_user:codetrack_pass@db:5432/codetrack_db

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Comma-separated list, e.g. http://localhost:5173,https://codetrack.app
BACKEND_CORS_ORIGINS_RAW=http://localhost:5173

PERIODIC_SYNC_INTERVAL_MINUTES=360
